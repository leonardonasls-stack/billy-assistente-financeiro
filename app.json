{
  "expo": {
    "name": "billy-v2.0",
    "slug": "billy-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "billyv20",
    "userInterfaceStyle": "automatic",
    "ios": {
      "infoPlist": {
        "NSFaceIDUsageDescription": "O Billy precisa do FaceID para proteger suas finanças."
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Billy precisa acessar suas fotos para você escolher sua foto de perfil.",
          "cameraPermission": "O Billy precisa acessar sua câmera para você tirar sua foto de perfil."
        }
      ]
    ]
  }
}
